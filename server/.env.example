# Server
PORT=3000
API_URL=http://localhost:3000

# Auth
JWT_SECRET=

# Initial admin (created on first boot)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# ClickHouse
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=tracker
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=default

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/nexus_roas?schema=public

# Cloudflare Worker
WORKER_URL=https://nexus-worker.YOUR_ACCOUNT.workers.dev
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# Google Ads OAuth (optional)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Frontend URL (used in OAuth redirect)
FRONTEND_URL=http://localhost:8080

# Redis
REDIS_URL=redis://localhost:6379

# License
LICENSE_KEY=NEXUS-INTERNAL-OWNER
NEXUS_ADMIN_SECRET=change-this-to-a-random-secret
APP_DOMAIN=
