# ═══════════════════════════════════════════════════════════════════════════════
# Nexus ROAS — Environment Configuration Template
#
# Copy to .env.prod or .env.staging and fill in your values.
# NEVER commit .env.prod or .env.staging to git.
#
# Quick start:
#   cp .env.example .env.prod
#   nano .env.prod          # fill in values
#   make setup-infra        # init Swarm + Traefik (first time only)
#   make deploy             # deploy all services
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
# Main app domain (e.g. app.yourdomain.com)
APP_DOMAIN=app.yourdomain.com

# RabbitMQ management panel subdomain
MQ_DOMAIN=mq.yourdomain.com

# ── GitHub Container Registry (GHCR) ─────────────────────────────────────────
# Your GitHub username/org — images are published as ghcr.io/OWNER/nexus-server:VERSION
# CI/CD uses GITHUB_TOKEN automatically; no extra registry credentials needed.
GITHUB_OWNER=your-github-username

# Image version tag to deploy (e.g. 1.0.0)
IMAGE_VERSION=1.0.0

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
# Email used for TLS certificate notifications
LETSENCRYPT_EMAIL=you@example.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=nexus_user
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=nexus_roas_db

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=tracker
# Generate: openssl rand -hex 24
CLICKHOUSE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
CLICKHOUSE_DB=nexus_roas

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=nexus
# Generate: openssl rand -hex 24
RABBITMQ_PASS=CHANGE_ME_STRONG_PASSWORD

# ── Backend Auth ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_MIN_32_CHARS

# Initial admin account — created automatically on first startup
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Cloudflare Worker ─────────────────────────────────────────────────────────
# Worker URL — shown after `wrangler deploy` completes
WORKER_URL=https://nexus-worker.YOUR_ACCOUNT.workers.dev

# Cloudflare Account ID — https://dash.cloudflare.com → right sidebar
CF_ACCOUNT_ID=your_cloudflare_account_id

# KV Namespace ID — created by setup.sh or: wrangler kv namespace create SITE_CONFIG_KV
CF_KV_NAMESPACE_ID=your_kv_namespace_id

# API Token — needs permissions: Workers KV Storage (Edit), D1 (Edit), Workers Scripts (Edit)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=your_cloudflare_api_token

# ── Google Ads (optional) ─────────────────────────────────────────────────────
# Leave empty to disable Google Ads integration
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
